# Copy to .env and fill in real values for local development.
# .env is gitignored; .env.example is committed.

# Postgres — use the local docker-compose Postgres for dev
DATABASE_URL=postgres://shortlive:devpass@localhost:5432/shortlive

# Redis — use the local docker-compose Redis for dev
REDIS_URL=redis://localhost:6379/1

# Port the server listens on
PORT=3010

# Session signing key — generate with: openssl rand -base64 48
# Must be ≥ 32 characters
SESSION_SECRET=replace-me-generate-with-openssl-rand-base64-48

# Environment label: development | test | production
NODE_ENV=development

# Server-side pepper for hashing visitor IPs before storage. Must be ≥ 16
# chars. Generate with: openssl rand -base64 24
IP_HASH_PEPPER=dev-only-replace-in-prod

# Optional: path to a GeoLite2-City.mmdb file for country/lat-lon lookups.
# If unset or missing, geo fields on clicks are stored as NULL — the redirect
# still works.
# GEOLITE2_PATH=./data/GeoLite2-City.mmdb
